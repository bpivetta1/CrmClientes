# ==========================================================================
# WhaTicket - variaveis de ambiente para deploy no Coolify
# Copie para .env (ou cadastre no painel do Coolify) e preencha os valores.
# ==========================================================================

# --- Dominios publicos (defina os mesmos no Coolify por servico) ---
# Backend: aponte o dominio do servico "backend" (porta 8081) para este valor
BACKEND_URL=https://crmclienteback.nefo.pro
# Frontend: aponte o dominio do servico "frontend" (porta 3000) para este valor
FRONTEND_URL=https://crmcliente.nefo.pro

# --- Banco de dados (Postgres) ---
DB_NAME=whaticket
DB_USER=whaticket
DB_PASS=troque_esta_senha_forte

# --- Redis ---
REDIS_PASS=troque_esta_senha_redis

# --- Segredos JWT (gere: openssl rand -base64 32) ---
JWT_SECRET=gere_um_segredo_aleatorio
JWT_REFRESH_SECRET=gere_outro_segredo_aleatorio

# --- Limites (opcional) ---
USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
MASTER_KEY=

# --- Frontend ---
REACT_APP_HOURS_CLOSE_TICKETS_AUTO=24

# --- Integracoes opcionais (deixe vazio se nao usar) ---
OPENAI_API_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Evolution-GO (troca da engine Baileys) ---
# Deixe EVOLUTION_ENABLED=false por enquanto (migracao em andamento, em fases).
# Quando true, o WhaTicket usa a Evolution-GO no lugar da Baileys.
EVOLUTION_ENABLED=false
EVOLUTION_URL=https://evolution-go.nefo.pro
EVOLUTION_API_KEY=
EVOLUTION_TIMEOUT=30000
